# Példa környezeti változók — másold .env néven és töltsd ki a saját értékeiddel.
# FONTOS: ez a fájl NEM tartalmazhat valódi titkot. A tényleges .env gitignore-olt.

# MySQL kapcsolati string a Prisma datasource-hoz.
# Formátum: mysql://FELHASZNALO:JELSZO@HOST:PORT/ADATBAZIS
DATABASE_URL=mysql://user:password@localhost:3306/nemeth_horgaszat

# Futtatási környezet: development | production
# (production-ben a session süti "secure" lesz, ezért HTTPS szükséges)
NODE_ENV=development
